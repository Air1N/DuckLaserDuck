  - m_Id: 20303354654760960
    m_Localized: "les ennemis atteints de poison + br\xFBlure \xE9mettent un grand
      nuage de gaz br\xFBlant, qui empoisonne et enflamme les ennemis"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32889217360207872
    m_Localized: "les balles gagnent {addOnKillDmgModifierFlat} de d\xE9g\xE2ts \xE0
      chaque \xE9limination"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32889263577243648
    m_Localized: "les balles grossissent de {addOnKillSizeModifierMult} apr\xE8s
      chaque \xE9limination, et gagnent {addOnKillDmgModifierMult} de d\xE9g\xE2ts"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32889334100271104
    m_Localized: "Lorsque tu subis des d\xE9g\xE2ts, ton prochain tir inflige <color=orange>2x</color>
      de d\xE9g\xE2ts"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32889358754390016
    m_Localized: "les coups cons\xE9cutifs infligent des d\xE9g\xE2ts cumul\xE9s
      augment\xE9s de {addConsecutiveHitDamageModifierFlat}"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32889445299658752
    m_Localized: "les ennemis enflamm\xE9s subissent {addConductiveFlamesDmgModifierMult}
      de d\xE9g\xE2ts de la foudre"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32889525540888576
    m_Localized: tu peux accumuler {addCreditCardDebtLimit} worms de dette
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32889633053483008
    m_Localized: "inflige {addConsecutiveCriticalHitDamageModifierFlat} de d\xE9g\xE2ts
      suppl\xE9mentaires par coup critique cons\xE9cutif \xE0 un ennemi"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32889659897028608
    m_Localized: augmente la cadence de tir de {addFranticFirerateModMult} quand
      tes PV sont en dessous de 40%
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32889672802902016
    m_Localized: "les explosions sont affect\xE9es {addGamblerBombMult} de plus par
      les effets de chance"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32889709977018368
    m_Localized: "les balles se d\xE9sint\xE8grent en \xE9clats \xE0 <color=orange>20%</color>
      en vol"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32889757175521280
    m_Localized: "rester debout pendant <color=orange>3s</color> accorde toujours
      {addHaltDamageMult} de pr\xE9cision bonus et {addHaltSpreadMult} de d\xE9g\xE2ts
      pendant <color=orange>6s</color>"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32889826708692992
    m_Localized: la foudre peut percer <color=orange>+1</orange> ennemi
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32889844089888768
    m_Localized: "les tirs des drones sont de taille {addDroneBulletSizeModifierMult}
      et infligent {addDroneBulletDamageModifierFlat} de d\xE9g\xE2ts"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32890018845564928
    m_Localized: "les balles grossissent avec le temps, infligeant plus de d\xE9g\xE2ts"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32890114727354368
    m_Localized: "la cha\xEEne d'\xE9clairs peut se d\xE9clencher sur les rebonds"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32890159409274880
    m_Localized: gagne <color=orange>50-60</color> worms
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32890303089352704
    m_Localized: "les coups cons\xE9cutifs sur un ennemi seront critiques"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32890653888356352
    m_Localized: "lorsque tu subis des d\xE9g\xE2ts, ton prochain tir sera critique"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32890886521233408
    m_Localized: "le tir palpite et inflige <color=orange>+10</color> de d\xE9g\xE2ts
      suppl\xE9mentaires lorsqu'il est agrandi"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32890913192812544
    m_Localized: "les articles de la boutique co\xFBtent {addRewardsCardDiscount}
      de moins"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32890963482517504
    m_Localized: "les explosions projettent {addShrapnel} tirs d'\xE9clats"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32891030813679616
    m_Localized: "les tirs \xE9clat\xE9s sont toujours critiques"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32891189178015744
    m_Localized: dash {addDashCooldownModifierMult} plus souvent
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32891216277413888
    m_Localized: "Gagne {addWeakReplicationChance} de chance de faire appara\xEEtre
      un second tir, plus faible, apr\xE8s avoir tir\xE9"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 32906566104653824
    m_Localized: les balles grossissent de {addBulletGrowthPerBounce} par rebond
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
