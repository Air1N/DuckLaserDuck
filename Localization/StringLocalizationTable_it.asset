  - m_Id: 7568194891776
    m_Localized: rivestimento in gomma
    m_Metadata:
      m_Items: []
  - m_Id: 7744649261056
    m_Localized: I colpi rimbalzano sugli ostacoli {addBouncinessCount} volte invece
      di essere distrutti
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 7761657163776
    m_Localized: Brucia
    m_Metadata:
      m_Items: []
  - m_Id: 7898886402048
    m_Localized: "Aggiunge {addBurnChance} possibilit\xE0 per colpo di incendiare
      i nemici, aggiungendo {addBurnStacksPerShot} pile di danno da fuoco"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 7913402888192
    m_Localized: Gelo
    m_Metadata:
      m_Items: []
  - m_Id: 7918901620736
    m_Localized: "Aggiunge {addFrostChance} possibilit\xE0 per colpo di congelare
      i nemici con {addFrostStacksPerShot} pile di gelo, rallentandoli"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 7947909427200
    m_Localized: Veleno
    m_Metadata:
      m_Items: []
  - m_Id: 7995976151040
    m_Localized: "Aggiunge {addPoisonChance} possibilit\xE0 per colpo di avvelenare
      i nemici, aggiungendo {addPoisonStacksPerShot} pile di danno da veleno"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 8010836570112
    m_Localized: Raffica
    m_Metadata:
      m_Items: []
  - m_Id: 8015840374784
    m_Localized: "Aggiunge {addAdditionalProjectileChanceModifierFlat} possibilit\xE0
      di sparare {addProjectileCountModifierFlat} proiettili per tiro, ma con una
      dispersione di {addSpreadModifierFlat} gradi e un moltiplicatore di dispersione
      di {addSpreadModifierMult}"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 8072048242688
    m_Localized: Chaingun
    m_Metadata:
      m_Items: []
  - m_Id: 8094353551360
    m_Localized: "La cadenza di fuoco e la dispersione aumentano pi\xF9 a lungo spari
      (max {addChainGunMaxFirerateMult}/{addChainGunMaxSpreadMult}, dopo <color=orange>10</color>
      secondi)"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 8108177977344
    m_Localized: Fulmine a catena
    m_Metadata:
      m_Items: []
  - m_Id: 8145033326592
    m_Localized: "Aggiunge {addChainLightningOdds} possibilit\xE0 che un colpo fulmini
      {addChainLightningQty} nemico con fulmine a catena"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 8160229289984
    m_Localized: Aura di scatto
    m_Metadata:
      m_Items: []
  - m_Id: 8174280208384
    m_Localized: Lascia una grande aura dannosa quando scatti, infliggendo 20 danni
      a ogni nemico e respingendoli leggermente
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 8193129410560
    m_Localized: Piccolo
    m_Metadata:
      m_Items: []
  - m_Id: 8288293974016
    m_Localized: "I proiettili diventano {addBulletSizeModifierMult} pi\xF9 piccoli,
      ma infliggono {addDmgModifierMult} danni in pi\xF9"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 8322968285184
    m_Localized: Lento
    m_Metadata:
      m_Items: []
  - m_Id: 8324746670080
    m_Localized: "I proiettili si muovono {addBulletSpeedModifierMult} pi\xF9 lentamente,
      ma infliggono {addDmgModifierMult} danni in pi\xF9"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 8371068563456
    m_Localized: Riduci orbita
    m_Metadata:
      m_Items: []
  - m_Id: 8804960923648
    m_Localized: "I proiettili orbitano {addOrbitRadius} pi\xF9 vicino"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 8825185857536
    m_Localized: Occhio d'Aquila
    m_Metadata:
      m_Items: []
  - m_Id: 8852457222144
    m_Localized: Riduce la dispersione dei proiettili di {addSpreadModifierMult}
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 8866847879168
    m_Localized: Artiglieria Pesante
    m_Metadata:
      m_Items: []
  - m_Id: 8868659818496
    m_Localized: "Muovi {addPlayerMoveSpeedModifier} unit\xE0 pi\xF9 lentamente,
      ma +{addDmgModifierMult} danni"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 8928302821376
    m_Localized: Grande Area d'Effetto
    m_Metadata:
      m_Items: []
  - m_Id: 8951350521856
    m_Localized: "Le aree d'effetto diventano pi\xF9 grandi (esplosioni, ecc.)"
