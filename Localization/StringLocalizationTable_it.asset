      m_Items:
      - rid: 822829599387811843
  - m_Id: 11046778662912
    m_Localized: Potenza di fuoco
    m_Metadata:
      m_Items: []
  - m_Id: 11092228141056
    m_Localized: "Infliggi {addDmgModifierFlat} danni in pi\xF9 per colpo"
