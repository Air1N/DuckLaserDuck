    m_Localized: Estremamente precisi
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 9329076957184
    m_Localized: "Ottieni {addCriticalHitChance} probabilit\xE0 di colpo critico"
