    m_Metadata:
      m_Items: []
  - m_Id: 8439200199806976
    m_Localized: coltello infuocato
    m_Metadata:
      m_Items: []
  - m_Id: 8439289920163840
    m_Localized: "I proiettili ottengono {addBulletSpeedModifierMult} velocit\xE0
