      m_Items:
      - rid: 822829599387811843
  - m_Id: 9497310490624
    m_Localized: Brrrt
    m_Metadata:
      m_Items: []
  - m_Id: 9500124868608
    m_Localized: "Spara {addFirerateModifierFlat} colpi in pi\xF9 al secondo"
