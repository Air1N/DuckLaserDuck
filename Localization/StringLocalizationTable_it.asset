      m_Items:
      - rid: 822829599387811843
  - m_Id: 8968329064448
    m_Localized: Conservanti
    m_Metadata:
      m_Items: []
  - m_Id: 9030056636416
    m_Localized: "I proiettili rimangono per {addBulletLifetimeModifierMult} pi\xF9
