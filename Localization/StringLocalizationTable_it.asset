      m_Items:
      - rid: 822829599387811843
  - m_Id: 9039250550784
    m_Localized: Colpo Pesante
    m_Metadata:
      m_Items: []
  - m_Id: 9044715728896
    m_Localized: "I proiettili diventano {addBulletSizeModifierMult} pi\xF9 grandi
      e infliggono {addDmgModifierMult} danni in pi\xF9"
    m_Metadata:
      m_Items:
      - rid: 822829599387811843
  - m_Id: 9151876001792
